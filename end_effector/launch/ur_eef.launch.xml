<?xml version="1.0" encoding="UTF-8"?>
<launch>

    <!-- Add the name parameter -->
    <arg name="name" default="ur"/>
    <!-- Declare the robot type argument -->
    <arg name="ur_type" default="ur10e"/>

    <!-- Declare robot description -->
    <arg name="robot_description" default="$(command 'xacro $(find-pkg-share end_effector)/urdf/ur.urdf.xacro ur_type:=$(var ur_type) name:=$(var name)')" />

    <!-- Robot State Publisher -->
    <node name="robot_state_publisher" pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description" value="$(var robot_description)" />
    </node>

    <!-- Joint State Publisher -->
    <node name="joint_state_publisher" pkg="joint_state_publisher" exec="joint_state_publisher" output="screen" />

    <node pkg="rviz2" exec="rviz2" output="screen" args="-d $(find-pkg-share end_effector)/rviz/end_effector_config.rviz"/>

</launch>
